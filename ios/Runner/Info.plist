<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Beacon</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>beacon</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- P2-2: Google Maps Platform API key. In CI and local builds, override
	     via Xcode User-Defined build setting or xcconfig so the raw key is
	     never checked in (e.g. `GMS_API_KEY = $(inherited)` in Debug.xcconfig
	     and map `GMSApiKey = $(GMS_API_KEY)` here). Empty string = grey tiles,
	     not a crash. -->
	<key>GMSApiKey</key>
	<string>$(GMS_API_KEY)</string>
	<!-- P2-14: voice SOS. Shown when the user first taps the mic on the SOS
	     screen. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Beacon uses the microphone to transcribe spoken SOS messages when you hold the mic button.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Beacon converts your spoken SOS into text so rescuers receive your message.</string>
	<!-- P2-15: accelerometer-based fall detection runs locally; no network. -->
	<key>NSMotionUsageDescription</key>
	<string>Beacon uses motion sensors to detect falls and offer to auto-broadcast an SOS.</string>

	<!-- iOS BLE — P0 blockers ───────────────────────────────────────────────
	     NSBluetoothAlwaysUsageDescription: required by flutter_blue_plus and
	     ble_peripheral; iOS crashes on any BLE call without this key.        -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Beacon uses Bluetooth to relay emergency SOS messages to nearby devices in a peer-to-peer mesh network, even when the screen is off.</string>

	<!-- UIBackgroundModes: required for BLE scan and advertise to continue
	     after the app is backgrounded. Without these, all BLE activity stops
	     the moment the user leaves the app.                                   -->
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
		<string>bluetooth-peripheral</string>
	</array>

	<!-- Location — required by geolocator and google_maps_flutter.
	     PlatformException is thrown on every getCurrentPosition() call
	     without NSLocationWhenInUseUsageDescription.                          -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Beacon uses your location to attach GPS coordinates to SOS messages so rescuers know where you are.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Beacon may use your location in the background to continue stamping coordinates on relayed mesh packets.</string>

	<!-- Camera — required by mobile_scanner (rescuer QR code login).
	     The app crashes when the QR screen opens without this key.            -->
	<key>NSCameraUsageDescription</key>
	<string>Beacon uses the camera to scan the rescuer QR code provided during provisioning.</string>
</dict>
</plist>
